# Copy this file to .env.local and fill in your actual values

# Paystack API Keys (get from https://dashboard.paystack.com/settings/developers)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_test_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_test_key

# Your app URL (used for Paystack redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Claude API Key (for repurposing)
# Note: The app currently uses claude-sonnet-4-20250514 via fetch
ANTHROPIC_API_KEY=your_anthropic_key_here
